{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@tauri-apps/api/core": ["./src/lib/electron-adapter/core.ts"],
      "@tauri-apps/api/event": ["./src/lib/electron-adapter/event.ts"],
      "@tauri-apps/api/window": ["./src/lib/electron-adapter/window.ts"],
      "@tauri-apps/plugin-dialog": ["./src/lib/electron-adapter/plugin-dialog.ts"],
      "@tauri-apps/plugin-os": ["./src/lib/electron-adapter/plugin-os.ts"],
      "@tauri-apps/plugin-opener": ["./src/lib/electron-adapter/plugin-opener.ts"]
    },

    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
